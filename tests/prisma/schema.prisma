datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client"
  output          = "./generated"
  previewFeatures = ["typedSql"]
}

generator effect {
  provider         = "node ../dist/index.js"
  output           = "./generated/effect.ts"
  clientImportPath = "./client"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id       Int     @id @default(autoincrement())
  title    String
  content  String?
  authorId Int
  author   User    @relation(fields: [authorId], references: [id])
}

// snake_case model name: regression coverage for first-letter-capitalized Prisma types
model user_account {
  id    Int    @id @default(autoincrement())
  email String @unique
  score Int    @default(0)
}
