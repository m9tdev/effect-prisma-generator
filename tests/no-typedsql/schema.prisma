datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

generator effect {
  provider         = "node ../../dist/index.js"
  output           = "./generated/effect.ts"
  clientImportPath = "./client"
  // Opting out here keeps one leg of the suite type-checking the generated
  // output (via `tsc --noEmit` over tests/), so generator regressions that
  // emit type-invalid code are still caught.
  noCheck        = "false"
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
}
